### [MODIFY] [models.py](file:///D:/.PROJECT_1/backend/app/models.py)

#### Model `SchedulingSession` — Đợt xếp lịch

```python
class SchedulingSession(Base):
    __tablename__ = "scheduling_sessions"
    id = Column(Integer, primary_key=True)
    name = Column(String(200), nullable=False)            # "HK2 2025-2026"
    registration_list_id = Column(Integer, 
        ForeignKey("registration_lists.list_id"), nullable=True)  # Nguồn nguyện vọng
    created_at = Column(Date, default=datetime.utcnow)
    
    entries = relationship("SessionEntry", back_populates="session", 
                          cascade="all, delete-orphan")
    rows = relationship("TimetableRow", back_populates="session",
                       cascade="all, delete-orphan")
    registration_list = relationship("RegistrationList")
```

#### Model `SessionEntry` — Mỗi bộ (ngành, khóa, kì) trong đợt

```python
class SessionEntry(Base):
    __tablename__ = "session_entries"
    id = Column(Integer, primary_key=True)
    session_id = Column(Integer, 
        ForeignKey("scheduling_sessions.id", ondelete="CASCADE"), nullable=False)
    major_code = Column(String(20), nullable=False)   # "CNTT"
    batch_code = Column(String(10), nullable=False)    # "19"
    semester_index = Column(Integer, nullable=False)   # 4
    num_classes = Column(Integer, nullable=False, default=6)  # Số lớp khóa này
    
    session = relationship("SchedulingSession", back_populates="entries")
```

#### Model `TimetableRow` — Mỗi dòng trong bảng TKB

```python
class TimetableRow(Base):
    __tablename__ = "timetable_rows"
    id = Column(Integer, primary_key=True)
    session_id = Column(Integer, 
        ForeignKey("scheduling_sessions.id", ondelete="CASCADE"), nullable=False)
    
    # Thông tin lớp
    row_index = Column(Integer, nullable=False)               # STT
    class_name = Column(String(30), nullable=False)           # "CNTT 19-01"
    shift = Column(String(10), nullable=False, default="Sáng") # "Sáng" / "Chiều"
    
    # Thông tin môn
    subject_code = Column(String(30), nullable=True)
    subject_name = Column(String(200), nullable=False)
    credits = Column(Integer, nullable=True)
    theory_hours = Column(Integer, nullable=True)
    practice_hours = Column(Integer, nullable=True)
    room_type = Column(String(50), nullable=True)             # "Phòng thường"/"Phòng máy"
    
    # Kết quả xếp lịch (engine hoặc thủ công điền)
    lecturer_name = Column(String(200), nullable=True)        # GV chính
    practice_lecturer_name = Column(String(200), nullable=True) # GV thực hành
    day_morning = Column(String(10), nullable=True)           # "S-T2"
    day_afternoon = Column(String(10), nullable=True)         # "C-T3"
    
    session = relationship("SchedulingSession", back_populates="rows")
```

